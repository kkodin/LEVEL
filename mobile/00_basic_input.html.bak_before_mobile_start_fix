function fmt(x,d=3){return (Number.isFinite(+x)?+x:0).toFixed(d)}
function calcGeometry(p){
  const pts=[],curves=[]; let x=0,y=0,az=(p.alignment?.baseAz||0)*Math.PI/180, accum=0; pts.push({name:'BP',x,y,label:'発進点'});
  (p.alignment?.curves||[]).forEach((cd,i)=>{const L=+cd.L||0,R=+cd.R||0,IA=dmsToDeg(cd.deg,cd.min,cd.sec)*Math.PI/180,dir=cd.dir||'L'; const TL=R*Math.tan(IA/2),CL=R*IA,SL=R*(1/Math.cos(IA/2)-1); const ip={x:x+L*Math.cos(az),y:y+L*Math.sin(az)}; const bc={x:ip.x-TL*Math.cos(az),y:ip.y-TL*Math.sin(az)}; const outAz=az+(dir==='R'?IA:-IA); const ec={x:ip.x+TL*Math.cos(outAz),y:ip.y+TL*Math.sin(outAz)}; const roAz=az+(dir==='R'?Math.PI/2:-Math.PI/2); const ro={x:bc.x+R*Math.cos(roAz),y:bc.y+R*Math.sin(roAz)}; const straight=Math.hypot(bc.x-x,bc.y-y); const startDist=accum+straight,endDist=startDist+CL; accum=endDist; const c={id:i+1,L,R,IA,ia_deg:IA*180/Math.PI,dir,TL,CL,SL,ip,bc,ec,ro,inAz:az,outAz,startDist,endDist}; curves.push(c); pts.push({name:`IP${i+1}`,...ip,label:`交点${i+1}`},{name:`BC${i+1}`,...bc,label:`曲始${i+1}`},{name:`EC${i+1}`,...ec,label:`曲終${i+1}`},{name:`RO${i+1}`,...ro,label:`曲線中心${i+1}`}); x=ip.x;y=ip.y;az=outAz;});
  const finalL=+p.alignment?.finalL||0; let ep; if(curves.length){const last=curves[curves.length-1]; ep={x:last.ip.x+finalL*Math.cos(last.outAz),y:last.ip.y+finalL*Math.sin(last.outAz)}; accum += Math.hypot(ep.x-last.ec.x,ep.y-last.ec.y)}else{ep={x:x+finalL*Math.cos(az),y:y+finalL*Math.sin(az)};accum+=finalL} pts.push({name:'EP',...ep,label:'到達点'}); return {points:pts,curves,totalDistance:accum};
}
function calcJoint(p,c){const L=p.pipe.length, D=p.pipe.inner, t=p.pipe.thickness, R=c.R, S4=p.pipe.cushion||0; const den=Math.max(0.0001,R-D/2); const S1=(L*D/den)*1000+S4; const S2=(L*Math.max(0,D-t)/den)*1000+S4; const S3=(L*t/den)*1000+S4; const simple=(D*2*Math.sin((L/R)/2))*1000+S4; return {S1,S2,S3,S4,simple,margin:(p.pipe.allowOpen||60)-S1,ok:S1<=(p.pipe.allowOpen||60)};}

