const PIPE_SIZES=[250,300,350,400,450,500,600,700,800,900,1000,1100,1200,1350,1500,1650,1800,2000,2200,2400,2600,2800,3000];
const HUME_T={250:55,300:57,350:60,400:63,450:67,500:70,600:76,700:82,800:80,900:90,1000:100,1100:105,1200:115,1350:125,1500:140,1650:150,1800:160,2000:175,2200:190,2400:205,2600:220,2800:235,3000:250};

function hasUsableBase(p=getProject()){
  return !!(p && p.site && String(p.site.name||'').trim() && String(p.site.span||'').trim() && p.alignment && Array.isArray(p.alignment.curves));
}
function setAppLayout(){
  document.querySelector('main')?.classList.add('app-layout');
  if(!document.getElementById('rightPane')){
    const pane=document.createElement('div');
    pane.id='rightPane';
    pane.innerHTML='<div class="frame-title"><b id="rightPaneTitle">作業ページ</b><button class="secondary" type="button" onclick="showBasicPane()">基線入力へ戻る</button></div><iframe id="workFrame" title="作業ページ"></iframe>';
    document.querySelector('main')?.appendChild(pane);
  }
  const start=document.getElementById('startMenu');
  if(start){
    const p=getProject();
    const current=start.querySelector('#currentBaseInfo');
    current?.classList.toggle('empty',!hasUsableBase(p));
  }
}
function showBasicPane(){
  document.body.classList.remove('show-frame');
  document.getElementById('rightPaneTitle')&&(document.getElementById('rightPaneTitle').textContent='基本データ');
}
function showFramePage(title, file){
  if(!hasUsableBase()){
    alert('先に基線情報を入力または読み込んでください。');
    document.body.classList.remove('base-ready','show-frame');
    document.getElementById('startMenu')?.scrollIntoView({block:'start'});
    return;
  }
  saveCurrentBase(false);
  document.body.classList.add('show-frame');
  const titleEl=document.getElementById('rightPaneTitle');
  if(titleEl)titleEl.textContent=title;
  const frame=document.getElementById('workFrame');
  if(frame)frame.src=file;
}
function refreshCurrentChoice(){
  const p=getProject();
  const current=document.getElementById('currentBaseInfo');
  if(current)current.classList.toggle('empty',!hasUsableBase(p));
}

function n(id,def=0){const el=document.getElementById(id); const v=el?parseFloat(String(el.value).replace(',','')):NaN; return Number.isFinite(v)?v:def;}
function v(id,def=''){const el=document.getElementById(id);return el?el.value:def}
function set(id,val){const el=document.getElementById(id); if(el) el.value=val}
function today(){const d=new Date();return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`}
function dmsToDeg(d,m,s){return (+d||0)+(+m||0)/60+(+s||0)/3600}
function pipeDefault(size,cat='ヒューム管'){
  const inner=size/1000; let t=(HUME_T[size]||125)/1000; let unitW=24.5;
  if(cat==='レジン管'){t=Math.max(0.02, inner*0.045); unitW=19.5}
  if(cat==='鋼管'){t=size>=2000?0.019:(size>=1500?0.016:(size>=1000?0.0127:0.0095)); unitW=78.5}
  const outer=inner+2*t; const area=Math.PI/4*(outer*outer-inner*inner); const weight=area*unitW; const len=size<350?2.0:2.43;
  return {inner,outer,t,area,weight,len,centerR:(inner+t)/2};
}
function collectBase(){
  const curves=[]; document.querySelectorAll('.curve').forEach((el,i)=>curves.push({L:+el.querySelector('.cL').value||0,R:+el.querySelector('.cR').value||0,dir:el.querySelector('.cDir').value,deg:+el.querySelector('.cDeg').value||0,min:+el.querySelector('.cMin').value||0,sec:+el.querySelector('.cSec').value||0}));
  return {version:'split-2026-05-18',savedAt:new Date().toISOString(),site:{name:v('siteName'),span:v('spanName'),date:v('inputDate')},soil:{type:v('soilType'),gamma:n('soilWeight'),phi:n('soilPhi'),c:n('soilC'),N:n('soilN'),cover:n('soilH')},pipe:{category:v('pipeCategory'),strength:v('pipeStrength'),joint:v('jointType'),size:n('pipeSize'),inner:n('pipeInner'),outer:n('pipeOuter'),thickness:n('pipeT'),area:n('pipeArea'),weight:n('pipeWeight'),length:n('pipeLength'),cushion:n('cushionT'),cushionCrush:n('cushionCrush'),allowOpen:n('allowOpen'),allowForce:n('allowForce')},survey:{ox:n('instX'),oy:n('instY'),bx:n('bsX'),by:n('bsY')},alignment:{baseAz:n('baseAz'),curves,finalL:n('finalL')}};
}
function downloadJSON(obj,fn){const blob=new Blob([JSON.stringify(obj,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=fn||'project.json';a.click();URL.revokeObjectURL(a.href)}
function safeName(s){return (s||'現場').replace(/[\\/:*?"<>|\s]+/g,'_')}
function startNewBase(){document.getElementById('startMenu')?.scrollIntoView({block:'start'});document.getElementById('siteName')?.focus()}
function currentBase(){return getProject()||collectBase()}
function baseTitle(p){const site=p?.site?.name||'\u672a\u8a2d\u5b9a';const span=p?.site?.span||'\u672a\u8a2d\u5b9a';const date=p?.site?.date||'-';const saved=p?.savedAt?new Date(p.savedAt).toLocaleString():'-';return {site,span,date,saved}}
function renderCurrentBase(){const box=document.getElementById('currentBaseInfo');if(!box)return;const p=getProject();if(!hasUsableBase(p)){box.classList.add('empty');box.innerHTML='<b>ブラウザに記憶されている基線情報はありません</b><span class="note">基線JSONを読み込むか、新規入力を始めてください。</span>';return}box.classList.remove('empty');const t=baseTitle(p);box.innerHTML=`<b>現在表示されている基線情報</b><div>現場名: ${t.site}</div><div>スパン名: ${t.span}</div><div>入力日: ${t.date}</div><div>作成日時: ${t.saved}</div>`}function showWorkMenu(showForm=false){document.body.classList.add('base-ready');document.body.classList.toggle('base-form-visible',!!showForm);document.body.classList.remove('show-frame');setAppLayout();if(showForm)document.getElementById('baseForm')?.scrollIntoView({block:'start'});else document.getElementById('workMenu')?.scrollIntoView({block:'start'})}
function saveCurrentBase(download=false){if(!validateRequired())return null;const p=collectBase();localStorage.setItem('curvedJackingProject',JSON.stringify(p));renderCurrentBase();if(download)downloadJSON(p,`${safeName(p.site.name)}_${safeName(p.site.span)}_${p.site.date||today()}.json`);return p}
function validateRequired(){const required=[['siteName','\u73fe\u5834\u540d'],['spanName','\u30b9\u30d1\u30f3\u540d'],['inputDate','\u5165\u529b\u65e5']];for(const [id,label] of required){const el=document.getElementById(id);if(!String(el?.value||'').trim()){alert(label+'\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044\u3002');el?.focus();return false}}return true}function selectCurrentBase(){const p=getProject();if(p){applyBase(p);renderCurves(p.alignment?.curves||[]);showWorkMenu(false)}else{startNewBase()}}
function chooseBaseFile(){const input=document.getElementById('file');input.dataset.next='';input.click()}
function startNewBase(){document.body.classList.add('base-ready','base-form-visible');set('siteName','');set('spanName','');set('inputDate',today());document.getElementById('siteName')?.focus();document.getElementById('baseForm')?.scrollIntoView({block:'start'})}
function updateWorkMenuToggle(){
  const btn=document.querySelector('#workMenu .work-menu-toggle');
  if(btn)btn.textContent=document.body.classList.contains('work-menu-collapsed')?'開く':'閉じる';
}
function toggleWorkMenuCollapse(force){
  const next=typeof force==='boolean'?force:!document.body.classList.contains('work-menu-collapsed');
  document.body.classList.toggle('work-menu-collapsed',next);
